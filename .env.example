# Copy to `.env` and adjust. All values are optional; defaults run end-to-end
# with the TF-IDF retriever and no API keys.

# Which frameworks to ingest (comma-separated ids; empty = all fetchable).
# Options today: eu_ai_act, nist_ai_rmf
REGULUS_FRAMEWORKS=eu_ai_act,nist_ai_rmf

# Retriever: "tfidf" (no deps) or "embedding" (uses GKN's embedding store).
REGULUS_RETRIEVER=tfidf
REGULUS_TOP_K=5
REGULUS_CHUNK_SIZE=900
REGULUS_CHUNK_OVERLAP=150

# --- Embedding retriever (only if REGULUS_RETRIEVER=embedding) ---
# These are read by the underlying GKN embedding store:
#   EMBEDDING_CHOICE=small        # small|large (cloud) or local
#   EMBEDDING_FALLBACK_TO_LOCAL=true
#   OPENAI_API_KEY=...
#   OPENAI_BASE_URL=...            # Azure / gateway
#   OPENAI_API_VERSION=...         # for Azure
#   OPENAI_EMBEDDING_MODEL=text-embedding-3-small
